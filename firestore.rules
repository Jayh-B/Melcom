rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDefaultAdmin() {
      return isAuthenticated() && request.auth.token.email == "dm570692@gmail.com";
    }

    function isAdmin() {
      return isDefaultAdmin() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isManagerOrAdmin() {
      return isDefaultAdmin() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'sku', 'name', 'price', 'stock', 'category'])
        && data.name is string && data.name.size() > 0 && data.name.size() < 200
        && data.price is number && data.price >= 0
        && data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customerId', 'items', 'totalAmount', 'taxAmount', 'paymentMethod', 'status', 'createdAt'])
        && data.totalAmount is number && data.totalAmount >= 0
        && data.taxAmount is number && data.taxAmount >= 0;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'firstName', 'lastName', 'email', 'phone', 'loyaltyPoints'])
        && data.email is string
        && data.loyaltyPoints is number && data.loyaltyPoints >= 0;
    }

    function isValidInteraction(data) {
      return data.keys().hasAll(['userId', 'productId', 'type', 'timestamp'])
        && data.userId == request.auth.uid
        && data.type in ['view', 'cart'];
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'status'])
        && data.name is string && data.name.size() > 0
        && data.email is string;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Products ─────────────────────────────────────────────────────────────
    // Public read, manager/admin write
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isManagerOrAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    // Admin/manager can read all; anyone can create (guest checkout); only admin updates status
    match /orders/{orderId} {
      allow read: if isManagerOrAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow create: if isValidOrder(request.resource.data);
      allow update: if isManagerOrAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    // ── Customers ────────────────────────────────────────────────────────────
    // Users can read/update their own profile; admin can read all
    match /customers/{customerId} {
      allow read: if isManagerOrAdmin() || isOwner(customerId);
      allow create, update: if isManagerOrAdmin() || (isOwner(customerId) && isValidCustomer(request.resource.data));
      allow delete: if isAdmin();
    }

    // ── Suppliers ────────────────────────────────────────────────────────────
    // Manager and admin only
    match /suppliers/{supplierId} {
      allow read: if isManagerOrAdmin();
      allow create, update: if isManagerOrAdmin() && isValidSupplier(request.resource.data);
      allow delete: if isAdmin();
    }

    // ── Interactions ─────────────────────────────────────────────────────────
    // Authenticated users create their own; admin/manager can read for analytics
    match /interactions/{interactionId} {
      allow read: if isManagerOrAdmin();
      allow create: if isAuthenticated() && isValidInteraction(request.resource.data);
    }

    // ── Wishlists ────────────────────────────────────────────────────────────
    // Users can read/write only their own wishlist
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isManagerOrAdmin();
    }

    // ── Users (role management) ───────────────────────────────────────────────
    // Users can read their own doc; only admin can change roles
    match /users/{userId} {
      allow read: if isOwner(userId) || isManagerOrAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Health check (connection test) ───────────────────────────────────────
    // Anyone can attempt a read; permission will be denied by the default rule above
    // This is intentional — we just want to confirm connectivity
    match /_health/{doc} {
      allow read: if false;
    }
  }
}
