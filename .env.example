# ─── Firebase (already in firebase-applet-config.json — do NOT duplicate here) ───

# ─── Paystack (https://dashboard.paystack.com) ───────────────────────────────
# Public key used client-side in Paystack inline popup
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Secret key used SERVER-SIDE only (server.ts). Never expose to the browser.
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Firebase App Check reCAPTCHA v3 ─────────────────────────────────────────
# Register your site at https://console.firebase.google.com > App Check > reCAPTCHA v3
VITE_RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXX

# ─── Sentry Error Monitoring (https://sentry.io) ─────────────────────────────
VITE_SENTRY_DSN=https://xxxxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxxx

# ─── Google Gemini AI (https://aistudio.google.com/app/apikey) ───────────────
VITE_GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# AI Studio also injects this at runtime — keep both for compatibility
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── SendGrid Email (https://sendgrid.com) ───────────────────────────────────
# Server-side only — for order confirmation emails
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=noreply@melcom.com.gh

# ─── App version (optional — shown in Sentry releases) ───────────────────────
VITE_APP_VERSION=1.0.0

# ─── Development helpers ─────────────────────────────────────────────────────
# Set to true to enable Firebase App Check debug token (dev only — never in prod)
VITE_APP_CHECK_DEBUG=true
