{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array" },
        "brand": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "specifications": { "type": "object" },
        "variations": { "type": "array" }
      },
      "required": ["id", "sku", "name", "price", "stock", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "taxAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "paymentReference": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Paid", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingDetails": { "type": "object" }
      },
      "required": ["id", "customerId", "items", "totalAmount", "taxAmount", "paymentMethod", "status", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "lastPurchase": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "phone", "loyaltyPoints"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A product supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "categories": { "type": "array" },
        "paymentTerms": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name", "email", "status"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A user interaction with a product.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["view", "cart"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "type", "timestamp"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "A customer's saved product IDs.",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items"]
    },
    "UserRole": {
      "title": "UserRole",
      "description": "A platform user with an assigned role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}":       { "schema": "Product",     "description": "Product catalogue." },
    "/orders/{orderId}":           { "schema": "Order",       "description": "Customer orders." },
    "/customers/{customerId}":     { "schema": "Customer",    "description": "CRM customer profiles." },
    "/suppliers/{supplierId}":     { "schema": "Supplier",    "description": "Supply chain suppliers." },
    "/interactions/{interactionId}": { "schema": "Interaction", "description": "Behavioural interaction events." },
    "/wishlists/{userId}":         { "schema": "Wishlist",    "description": "Per-user wishlist (keyed by uid)." },
    "/users/{userId}":             { "schema": "UserRole",    "description": "Platform users and their roles." }
  }
}
